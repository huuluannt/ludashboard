# LuDashboard Environment Variables

# To enable real Google OAuth login, you must provide a valid Client ID.
# 1. Go to Google Cloud Console (https://console.cloud.google.com/)
# 2. Create a new project or select an existing one
# 3. Navigate to APIs & Services > Credentials
# 4. Create an "OAuth client ID" (Application type: Web application)
# 5. Add "http://localhost:5173" to Authorized JavaScript origins
# 6. Copy the Client ID and paste it here:

VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Firebase Config (Required for Cloud Sync)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# LuMusic / optional private server-side YouTube Data API fallback
# By default LuMusic reuses each user's local LuVideo key, so public users do NOT consume your server key.
# Set YOUTUBE_ENABLE_SERVER_KEY_FOR_MUSIC=true only for a private deployment where you accept shared quota usage.
YOUTUBE_ENABLE_SERVER_KEY_FOR_MUSIC=false
YOUTUBE_API_KEY=

# Native AI Modules (server-side only; do NOT prefix with VITE_)
# Use free-tier API keys for personal development. Do not enable automatic billing.
# Groq docs: https://console.groq.com/docs/text-chat
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Gemini API docs: https://ai.google.dev/gemini-api/docs
# gemini-2.5-flash is stable and free-tier friendly; gemini-2.5-flash-lite has higher throughput if you prefer.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# LuCalendar Google Calendar OAuth (server-side only; do NOT prefix with VITE_)
# Google Cloud Console:
# - Enable Google Calendar API
# - Enable Gmail API if using LuGmail
# - Enable Google Drive API if using LuDrive
# - Create OAuth Client ID, type Web application
# - Add these redirect URIs as needed:
#   http://localhost:5173/api/calendar/callback
#   http://localhost:5173/api/gmail/callback
#   http://localhost:5173/api/drive/callback
# - Add required scopes for each enabled module:
#   https://www.googleapis.com/auth/calendar.events
#   https://www.googleapis.com/auth/calendar.calendarlist.readonly
#   https://www.googleapis.com/auth/gmail.modify
#   https://www.googleapis.com/auth/drive.metadata.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:5173/api/calendar/callback
GOOGLE_GMAIL_REDIRECT_URI=http://localhost:5173/api/gmail/callback
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:5173/api/drive/callback

# LuOnedrive Microsoft Graph OAuth (server-side only; do NOT prefix with VITE_)
# Microsoft Entra admin center:
# - Register an app, supported account types: personal Microsoft accounts and/or organizational accounts
# - Add Web redirect URI:
#   http://localhost:5173/api/onedrive/callback
# - Add delegated Microsoft Graph permissions:
#   User.Read
#   Files.Read
#   offline_access
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_ONEDRIVE_REDIRECT_URI=http://localhost:5173/api/onedrive/callback

# Google Workspace token storage (server-side only)
# Required for LuCalendar, LuGmail, LuDrive, and LuOnedrive in local development and Vercel production.
# These modules do not write OAuth tokens to disk.
# Use Vercel KV / Upstash Redis.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Upstash naming is also supported:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional namespace if sharing one Redis database across apps.
LUCALENDAR_REDIS_PREFIX=ludashboard:lucalendar
LUGMAIL_REDIS_PREFIX=ludashboard:lugmail
LUDRIVE_REDIS_PREFIX=ludashboard:ludrive
LUONEDRIVE_REDIS_PREFIX=ludashboard:luonedrive

# Recommended: a stable app secret used to encrypt Google OAuth tokens before storing them in Redis.
# If omitted, Google/Microsoft modules derive encryption from LUCALENDAR_TOKEN_SECRET or the Upstash token.
LUCALENDAR_TOKEN_SECRET=
GOOGLE_TOKEN_SECRET=
MICROSOFT_TOKEN_SECRET=
